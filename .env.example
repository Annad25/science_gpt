# ── LLM ──
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-5-mini
LLM_TEMPERATURE=1

# ── Embeddings ──
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Qdrant ──
QDRANT_MODE=file
QDRANT_PATH=./qdrant_data
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ── Retrieval ──
RETRIEVAL_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── arXiv ──
ARXIV_MAX_PAPERS=15
# ARXIV_QUERIES=["artificial intelligence","climate change science","machine learning healthcare"]

# ── Cache ──
CACHE_TTL_SECONDS=600
CACHE_MAX_SIZE=256

# ── API ──
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# ── Sandboxed execution ──
CODE_EXEC_TIMEOUT_SECONDS=10
CODE_EXEC_MAX_MEMORY_MB=128
